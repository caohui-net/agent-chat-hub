# yamllint configuration for AI Role System
# See: https://yamllint.readthedocs.io/

extends: default

rules:
  line-length:
    max: 120
    level: warning

  indentation:
    spaces: 2
    indent-sequences: true

  comments:
    min-spaces-from-content: 2

  document-start:
    present: false

  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']

  braces:
    max-spaces-inside: 1

  brackets:
    max-spaces-inside: 1

ignore: |
  .git/
  __pycache__/
  *.pyc
  venv/
  .venv/
