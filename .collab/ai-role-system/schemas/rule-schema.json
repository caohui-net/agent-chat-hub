{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/rule-schema.json",
  "title": "Atomic Rule Schema",
  "description": "Schema for atomic engineering rules",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "scope", "condition", "requirement", "severity", "verification", "source", "owner", "reviewer"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[A-Z]+-\\d{3}$",
        "description": "Unique rule ID (e.g., API-001, DB-002)"
      },
      "name": {
        "type": "string",
        "minLength": 5,
        "maxLength": 100,
        "description": "Human-readable rule name"
      },
      "scope": {
        "type": "string",
        "enum": ["backend", "frontend", "database", "infrastructure", "security", "testing", "all"],
        "description": "Scope where this rule applies"
      },
      "condition": {
        "type": "string",
        "minLength": 5,
        "description": "When this rule is triggered (clear condition)"
      },
      "requirement": {
        "type": "string",
        "minLength": 5,
        "description": "What must be done (executable and verifiable)"
      },
      "severity": {
        "type": "string",
        "enum": ["blocking", "warning", "info"],
        "description": "Rule severity level"
      },
      "verification": {
        "type": "string",
        "minLength": 5,
        "description": "How to verify compliance (test/check/tool)"
      },
      "source": {
        "type": "string",
        "description": "Source document or standard (with reference)"
      },
      "owner": {
        "type": "string",
        "description": "Role responsible for executing this rule"
      },
      "reviewer": {
        "type": "string",
        "description": "Role responsible for reviewing compliance"
      },
      "examples": {
        "type": "object",
        "properties": {
          "pass": {
            "oneOf": [
              {"type": "string"},
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["case", "code"],
                  "properties": {
                    "case": {"type": "string"},
                    "code": {"type": "string"}
                  }
                }
              }
            ],
            "description": "Example(s) that pass this rule"
          },
          "fail": {
            "oneOf": [
              {"type": "string"},
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["case", "code"],
                  "properties": {
                    "case": {"type": "string"},
                    "code": {"type": "string"}
                  }
                }
              }
            ],
            "description": "Example(s) that fail this rule"
          }
        },
        "description": "Pass and fail examples"
      },
      "tags": {
        "type": "array",
        "items": {"type": "string"},
        "description": "Optional tags for categorization"
      }
    }
  }
}
